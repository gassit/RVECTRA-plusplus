generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model CableReference {
  id        String   @id @default(cuid())
  mark      String   @unique
  section   Float
  material  String
  voltage   Float
  iDop      Float
  r0        Float
  x0        Float
  createdAt DateTime @default(now())
  cables    Cable[]
}

model BreakerReference {
  id               String    @id @default(cuid())
  type             String    @unique
  ratedCurrent     Float
  breakingCapacity Float
  curve            String
  poles            Int
  createdAt        DateTime  @default(now())
  breakers         Breaker[]
}

model TransformerReference {
  id           String        @id @default(cuid())
  type         String        @unique
  power        Float
  primaryKV    Float
  secondaryKV  Float
  ukz          Float
  pkz          Float
  createdAt    DateTime      @default(now())
  transformers Transformer[]
}

model Element {
  id                String       @id @default(cuid())
  elementId         String       @unique
  name              String
  type              String
  parentId          String?
  voltageLevel      Float?
  posX              Float?
  posY              Float?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  targetConnections Connection[] @relation("TargetConnection")
  sourceConnections Connection[] @relation("SourceConnection")
  deviceSlots       DeviceSlot[]
  parent            Element?     @relation("ElementHierarchy", fields: [parentId], references: [id])
  children          Element[]    @relation("ElementHierarchy")
}

model DeviceSlot {
  id        String   @id @default(cuid())
  slotId    String   @unique
  elementId String
  slotType  String
  position  String?
  createdAt DateTime @default(now())
  devices   Device[]
  element   Element  @relation(fields: [elementId], references: [id])
}

model Device {
  id          String       @id @default(cuid())
  deviceId    String       @unique
  slotId      String
  deviceType  String
  status      String       @default("active")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  breaker     Breaker?
  slot        DeviceSlot   @relation(fields: [slotId], references: [id])
  load        Load?
  meter       Meter?
  transformer Transformer?
}

model Breaker {
  id             String            @id @default(cuid())
  deviceId       String            @unique
  refId          String?
  ratedCurrent   Float
  currentSetting Float?
  status         String            @default("on")
  lastTripReason String?
  tripCount      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  ref            BreakerReference? @relation(fields: [refId], references: [id])
  device         Device            @relation(fields: [deviceId], references: [id])
}

model Meter {
  id           String         @id @default(cuid())
  deviceId     String         @unique
  meterType    String
  serialNumber String?
  accuracy     Float?
  tariff       Int            @default(1)
  status       String         @default("active")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  device       Device         @relation(fields: [deviceId], references: [id])
  readings     MeterReading[]
}

model MeterReading {
  id             String   @id @default(cuid())
  meterId        String
  timestamp      DateTime
  activeEnergy   Float
  reactiveEnergy Float?
  powerP         Float?
  powerQ         Float?
  voltage        Float?
  current        Float?
  createdAt      DateTime @default(now())
  meter          Meter    @relation(fields: [meterId], references: [id])
}

model Transformer {
  id          String                @id @default(cuid())
  deviceId    String                @unique
  refId       String?
  power       Float
  primaryKV   Float
  secondaryKV Float
  loadPercent Float                 @default(0)
  status      String                @default("active")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  ref         TransformerReference? @relation(fields: [refId], references: [id])
  device      Device                @relation(fields: [deviceId], references: [id])
}

model Load {
  id        String   @id @default(cuid())
  deviceId  String   @unique
  name      String
  powerP    Float
  powerQ    Float?
  cosPhi    Float    @default(0.9)
  category  Int      @default(3)
  status    String   @default("connected")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  device    Device   @relation(fields: [deviceId], references: [id])
}

model Cable {
  id          String          @id @default(cuid())
  cableId     String          @unique
  name        String?
  refId       String?
  length      Float
  section     Float
  material    String          @default("copper")
  iDop        Float?
  status      String          @default("active")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  ref         CableReference? @relation(fields: [refId], references: [id])
  connections Connection[]
}

model Connection {
  id        String   @id @default(cuid())
  sourceId  String
  targetId  String
  cableId   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  cable     Cable?   @relation(fields: [cableId], references: [id])
  target    Element  @relation("TargetConnection", fields: [targetId], references: [id])
  source    Element  @relation("SourceConnection", fields: [sourceId], references: [id])
}

model ValidationRule {
  id          String             @id @default(cuid())
  name        String             @unique
  description String
  formula     String
  severity    String             @default("error")
  enabled     Boolean            @default(true)
  createdAt   DateTime           @default(now())
  results     ValidationResult[]
}

model ValidationResult {
  id           String         @id @default(cuid())
  ruleId       String
  elementId    String?
  connectionId String?
  status       String
  message      String
  value        Float?
  limit        Float?
  createdAt    DateTime       @default(now())
  rule         ValidationRule @relation(fields: [ruleId], references: [id])
}

model CalculatedParams {
  id                  String   @id @default(cuid())
  elementId           String   @unique
  current             Float?
  voltage             Float?
  power               Float?
  voltageDrop         Float?
  shortCircuitCurrent Float?
  loadFactor          Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Alarm {
  id             String    @id @default(cuid())
  elementId      String?
  type           String
  severity       String
  message        String
  acknowledged   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?
}
