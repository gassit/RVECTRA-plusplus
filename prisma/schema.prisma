generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Alarm {
  id             String    @id
  elementId      String?
  type           String
  severity       String
  message        String
  acknowledged   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?
}

model Breaker {
  id               String            @id
  deviceId         String            @unique
  refId            String?
  breakerType      String            @default("MCB")  // MCB | MCCB | RCD | RCBO
  ratedCurrent     Float
  currentSetting   Float?
  leakageCurrent   Float?            // Ток утечки (мА) - для RCD/RCBO
  lastTripReason   String?
  tripCount        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  Device           Device            @relation(fields: [deviceId], references: [id])
  BreakerReference BreakerReference? @relation(fields: [refId], references: [id])
}

model BreakerReference {
  id               String    @id
  type             String    @unique
  breakerType      String    @default("MCB")  // MCB | MCCB | RCD | RCBO
  ratedCurrent     Float
  breakingCapacity Float
  curve            String
  poles            Int
  leakageCurrent   Float?    // Ток утечки (мА) - для RCD/RCBO
  createdAt        DateTime  @default(now())
  Breaker          Breaker[]
}

model Cable {
  id             String          @id
  cableId        String          @unique
  name           String?
  refId          String?
  length         Float
  section        Float
  material       String          @default("copper")
  iDop           Float?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  CableReference CableReference? @relation(fields: [refId], references: [id])
  Connection     Connection[]
}

model CableReference {
  id        String   @id
  mark      String   @unique
  section   Float
  material  String
  voltage   Float
  iDop      Float
  r0        Float
  x0        Float
  createdAt DateTime @default(now())
  Cable     Cable[]
}

model CalculatedParams {
  id                  String   @id
  elementId           String   @unique
  current             Float?
  voltage             Float?
  power               Float?
  voltageDrop         Float?
  shortCircuitCurrent Float?
  loadFactor          Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime
}

model Connection {
  id                                   String   @id
  sourceId                             String
  targetId                             String
  cableId                              String?
  order                                Int      @default(0)
  electricalStatus                     String   @default("DEAD")
  operationalStatus                    String   @default("ON")
  createdAt                            DateTime @default(now())
  Element_Connection_sourceIdToElement Element  @relation("Connection_sourceIdToElement", fields: [sourceId], references: [id])
  Element_Connection_targetIdToElement Element  @relation("Connection_targetIdToElement", fields: [targetId], references: [id])
  Cable                                Cable?   @relation(fields: [cableId], references: [id])
}

model Device {
  id          String       @id
  deviceId    String       @unique
  slotId      String
  deviceType  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  Breaker     Breaker?
  DeviceSlot  DeviceSlot   @relation(fields: [slotId], references: [id])
  Load        Load?
  Meter       Meter?
  Transformer Transformer?
}

model DeviceSlot {
  id        String   @id
  slotId    String   @unique
  elementId String
  slotType  String
  position  String?
  createdAt DateTime @default(now())
  Device    Device[]
  Element   Element  @relation(fields: [elementId], references: [id])
}

model Element {
  id                                      String       @id
  elementId                               String       @unique
  name                                    String
  type                                    String
  parentId                                String?
  voltageLevel                            Float?
  posX                                    Float?
  posY                                    Float?
  electricalStatus                        String       @default("DEAD")
  operationalStatus                       String       @default("ON")
  createdAt                               DateTime     @default(now())
  updatedAt                               DateTime
  Connection_Connection_sourceIdToElement Connection[] @relation("Connection_sourceIdToElement")
  Connection_Connection_targetIdToElement Connection[] @relation("Connection_targetIdToElement")
  DeviceSlot                              DeviceSlot[]
  Element                                 Element?     @relation("ElementToElement", fields: [parentId], references: [id])
  other_Element                           Element[]    @relation("ElementToElement")
  AVRInputs                               AVRInput[]   // Элементы, которые мониторит АВР
  AVROutputs                              AVROutput[]  // Элементы, которыми управляет АВР
}

// === АВР (КОНТРОЛЛЕР УПРАВЛЕНИЯ) ===
// АВР не находится в цепи питания, а управляет выключателями
model AVR {
  id                String   @id
  name              String              // "АВР ГРЩ1"
  description       String?             // Описание
  
  mode              String   @default("AUTO")  // AUTO | MANUAL | OFF
  status            String   @default("OK")    // OK | SWITCHING | FAULT | OFF
  
  switchoverDelay   Float    @default(0.5)     // Задержка переключения (сек)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  inputs            AVRInput[]          // Что мониторим (входы)
  outputs           AVROutput[]         // Чем управляем (выходы)
  switchovers       AVRSwitchover[]     // История переключений
  
  @@map("avr")
}

// === ВХОДЫ АВР (мониторинг элементов) ===
model AVRInput {
  id              String   @id
  avrId           String
  
  elementId       String              // Какой элемент мониторим (QF1, QF2...)
  role            String              // "PRIMARY" | "SECONDARY" | "DGU" | "RESERVE"
  priority        Int                 // Приоритет (1 = основной, 2 = резерв...)
  
  // Какой сигнал считаем
  signalType      String   @default("ELECTRICAL")  // ELECTRICAL (LIVE/DEAD) | OPERATIONAL (ON/OFF)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  avr             AVR      @relation(fields: [avrId], references: [id], onDelete: Cascade)
  element         Element  @relation(fields: [elementId], references: [id])
  
  @@index([avrId])
  @@map("avr_input")
}

// === ВЫХОДЫ АВР (управление элементами) ===
model AVROutput {
  id              String   @id
  avrId           String
  
  elementId       String              // Каким элементом управляем (QF3, QF4...)
  role            String              // "MAIN_BREAKER" | "RESERVE_BREAKER" | "DGU_BREAKER"
  
  // Логика управления
  actionOn        String   @default("CLOSE")   // "CLOSE" = включить при активации
  actionOff       String   @default("OPEN")    // "OPEN" = отключить при деактивации
  
  isActive        Boolean  @default(false)     // Текущее состояние выхода
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  avr             AVR      @relation(fields: [avrId], references: [id], onDelete: Cascade)
  element         Element  @relation(fields: [elementId], references: [id])
  
  @@index([avrId])
  @@map("avr_output")
}

// === ИСТОРИЯ ПЕРЕКЛЮЧЕНИЙ АВР ===
model AVRSwitchover {
  id              String   @id
  avrId           String
  
  triggerElement  String?             // Какой элемент вызвал переключение
  triggerReason   String              // "PRIMARY_LOST" | "PRIMARY_RESTORED" | "MANUAL" | "ALL_SOURCES_LOST"
  
  actions         String              // JSON: [{elementId, elementName, fromState, toState}]
  
  delay           Float?              // Фактическая задержка (сек)
  success         Boolean  @default(true)
  
  timestamp       DateTime @default(now())
  
  avr             AVR      @relation(fields: [avrId], references: [id], onDelete: Cascade)
  
  @@map("avr_switchover")
}

model Load {
  id        String   @id
  deviceId  String   @unique
  name      String
  powerP    Float
  powerQ    Float?
  cosPhi    Float    @default(0.9)
  category  Int      @default(3)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Device    Device   @relation(fields: [deviceId], references: [id])
}

model Meter {
  id           String         @id
  deviceId     String         @unique
  meterType    String
  serialNumber String?
  accuracy     Float?
  tariff       Int            @default(1)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  Device       Device         @relation(fields: [deviceId], references: [id])
  MeterReading MeterReading[]
}

model MeterReading {
  id             String   @id
  meterId        String
  timestamp      DateTime
  activeEnergy   Float
  reactiveEnergy Float?
  powerP         Float?
  powerQ         Float?
  voltage        Float?
  current        Float?
  createdAt      DateTime @default(now())
  Meter          Meter    @relation(fields: [meterId], references: [id])
}

model Transformer {
  id                   String                @id
  deviceId             String                @unique
  refId                String?
  power                Float
  primaryKV            Float
  secondaryKV          Float
  loadPercent          Float                 @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime
  Device               Device                @relation(fields: [deviceId], references: [id])
  TransformerReference TransformerReference? @relation(fields: [refId], references: [id])
}

model TransformerReference {
  id          String        @id
  type        String        @unique
  power       Float
  primaryKV   Float
  secondaryKV Float
  ukz         Float
  pkz         Float
  createdAt   DateTime      @default(now())
  Transformer Transformer[]
}

model ValidationResult {
  id             String         @id
  ruleId         String
  elementId      String?
  connectionId   String?
  status         String
  message        String
  value          Float?
  limit          Float?
  createdAt      DateTime       @default(now())
  ValidationRule ValidationRule @relation(fields: [ruleId], references: [id])
}

model ValidationRule {
  id               String             @id
  name             String             @unique
  description      String
  formula          String
  severity         String             @default("error")
  enabled          Boolean            @default(true)
  createdAt        DateTime           @default(now())
  ValidationResult ValidationResult[]
}
