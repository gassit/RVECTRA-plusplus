generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Alarm {
  id             String    @id
  elementId      String?
  type           String
  severity       String
  message        String
  acknowledged   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?
}

model Breaker {
  id               String            @id
  deviceId         String            @unique
  refId            String?
  ratedCurrent     Float
  currentSetting   Float?
  status           String            @default("on")
  lastTripReason   String?
  tripCount        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  BreakerReference BreakerReference? @relation(fields: [refId], references: [id])
  Device           Device            @relation(fields: [deviceId], references: [id])
}

model BreakerReference {
  id               String    @id
  type             String    @unique
  ratedCurrent     Float
  breakingCapacity Float
  curve            String
  poles            Int
  createdAt        DateTime  @default(now())
  Breaker          Breaker[]
}

model Cable {
  id             String          @id
  cableId        String          @unique
  name           String?
  refId          String?
  length         Float
  section        Float
  material       String          @default("copper")
  iDop           Float?
  status         String          @default("active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  CableReference CableReference? @relation(fields: [refId], references: [id])
  Connection     Connection[]
}

model CableReference {
  id        String   @id
  mark      String   @unique
  section   Float
  material  String
  voltage   Float
  iDop      Float
  r0        Float
  x0        Float
  createdAt DateTime @default(now())
  Cable     Cable[]
}

model CalculatedParams {
  id                  String   @id
  elementId           String   @unique
  current             Float?
  voltage             Float?
  power               Float?
  voltageDrop         Float?
  shortCircuitCurrent Float?
  loadFactor          Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime
}

model Connection {
  id                                   String   @id
  sourceId                             String
  targetId                             String
  cableId                              String?
  order                                Int      @default(0)
  createdAt                            DateTime @default(now())
  Cable                                Cable?   @relation(fields: [cableId], references: [id])
  Element_Connection_targetIdToElement Element  @relation("Connection_targetIdToElement", fields: [targetId], references: [id])
  Element_Connection_sourceIdToElement Element  @relation("Connection_sourceIdToElement", fields: [sourceId], references: [id])
}

model Device {
  id          String       @id
  deviceId    String       @unique
  slotId      String
  deviceType  String
  status      String       @default("active")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  Breaker     Breaker?
  DeviceSlot  DeviceSlot   @relation(fields: [slotId], references: [id])
  Load        Load?
  Meter       Meter?
  Transformer Transformer?
}

model DeviceSlot {
  id        String   @id
  slotId    String   @unique
  elementId String
  slotType  String
  position  String?
  createdAt DateTime @default(now())
  Device    Device[]
  Element   Element  @relation(fields: [elementId], references: [id])
}

model Element {
  id                                      String       @id
  elementId                               String       @unique
  name                                    String
  type                                    String
  parentId                                String?
  voltageLevel                            Float?
  posX                                    Float?
  posY                                    Float?
  createdAt                               DateTime     @default(now())
  updatedAt                               DateTime
  Connection_Connection_targetIdToElement Connection[] @relation("Connection_targetIdToElement")
  Connection_Connection_sourceIdToElement Connection[] @relation("Connection_sourceIdToElement")
  DeviceSlot                              DeviceSlot[]
  Element                                 Element?     @relation("ElementToElement", fields: [parentId], references: [id])
  other_Element                           Element[]    @relation("ElementToElement")
}

model Load {
  id        String   @id
  deviceId  String   @unique
  name      String
  powerP    Float
  powerQ    Float?
  cosPhi    Float    @default(0.9)
  category  Int      @default(3)
  status    String   @default("connected")
  createdAt DateTime @default(now())
  updatedAt DateTime
  Device    Device   @relation(fields: [deviceId], references: [id])
}

model Meter {
  id           String         @id
  deviceId     String         @unique
  meterType    String
  serialNumber String?
  accuracy     Float?
  tariff       Int            @default(1)
  status       String         @default("active")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  Device       Device         @relation(fields: [deviceId], references: [id])
  MeterReading MeterReading[]
}

model MeterReading {
  id             String   @id
  meterId        String
  timestamp      DateTime
  activeEnergy   Float
  reactiveEnergy Float?
  powerP         Float?
  powerQ         Float?
  voltage        Float?
  current        Float?
  createdAt      DateTime @default(now())
  Meter          Meter    @relation(fields: [meterId], references: [id])
}

model Transformer {
  id                   String                @id
  deviceId             String                @unique
  refId                String?
  power                Float
  primaryKV            Float
  secondaryKV          Float
  loadPercent          Float                 @default(0)
  status               String                @default("active")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime
  TransformerReference TransformerReference? @relation(fields: [refId], references: [id])
  Device               Device                @relation(fields: [deviceId], references: [id])
}

model TransformerReference {
  id          String        @id
  type        String        @unique
  power       Float
  primaryKV   Float
  secondaryKV Float
  ukz         Float
  pkz         Float
  createdAt   DateTime      @default(now())
  Transformer Transformer[]
}

model ValidationResult {
  id             String         @id
  ruleId         String
  elementId      String?
  connectionId   String?
  status         String
  message        String
  value          Float?
  limit          Float?
  createdAt      DateTime       @default(now())
  ValidationRule ValidationRule @relation(fields: [ruleId], references: [id])
}

model ValidationRule {
  id               String             @id
  name             String             @unique
  description      String
  formula          String
  severity         String             @default("error")
  enabled          Boolean            @default(true)
  createdAt        DateTime           @default(now())
  ValidationResult ValidationResult[]
}
